# Copy to .env.local and fill in real values.
# Firebase Web SDK config (apiKey is not a secret — it identifies the project,
# not who can access it; access is gated by Security Rules + Auth).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: server-side TTS endpoint. Leave unset to fall back to Web Speech API.
# VITE_TTS_ENDPOINT=/api/tts

# Free local neural Uyghur TTS:
# 1. Run `npm run tts:mms`
# 2. Point the app at the local server:
# VITE_TTS_ENDPOINT=http://127.0.0.1:7861/api/tts
