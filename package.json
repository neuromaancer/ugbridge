{
  "name": "ugbridge",
  "private": true,
  "version": "1.0.0",
  "license": "GPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "dictionary:build": "node scripts/build_dictionary_dataset.mjs",
    "tts:mms": "python3 scripts/mms_tts_server.py",
    "typecheck": "tsc -b --noEmit",
    "deploy": "npm run build && npx firebase-tools deploy --only hosting"
  },
  "dependencies": {
    "firebase": "^12.13.0",
    "lucide-react": "^1.16.0",
    "msedge-tts": "^2.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.7.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.5.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
